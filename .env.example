DATABASE_URL="postgresql://beta:beta@localhost:5432/betta?schema=public"
SESSION_SECRET="change-this-in-production"

# Image generation (Gemini Imagen API)
# GEMINI_API_KEY=your-gemini-api-key

# S3-compatible storage (Render Object Storage / Cloudflare R2 / AWS S3)
# Leave empty for local filesystem (dev mode)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=betta-assets
# S3_PUBLIC_URL=
